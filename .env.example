# Kopieren nach .env und ausfüllen. Die .env liegt außerhalb des Git-Repos (SPEC 8.4).

# Pfad zur SQLite-Datenbank (Standard: ./daten/wm26.db)
#WM26_DB_PFAD=/pfad/zur/wm26.db

# Cookies nur über HTTPS ausliefern (hinter Tailscale Funnel: 1, lokale Entwicklung: 0)
WM26_COOKIE_SECURE=1

# Fußball-API (SPEC 12.1, Kandidat football-data.org; ohne Token bleibt der Sync aus)
WM26_API_PROVIDER=football-data
WM26_API_TOKEN=
WM26_API_BASIS_URL=https://api.football-data.org/v4
# Wettbewerbs-Code der WM bei football-data.org
WM26_API_WETTBEWERB=WC

# Spieltags-Sync-Intervall in Minuten (0 = Scheduler aus)
WM26_SYNC_INTERVALL_MINUTEN=60
# Erlaubte API-Calls/Minute des Tarifs (Free 10, "Free w/ Livescores" 20)
WM26_API_RATE_PRO_MINUTE=10
# Poll-Takt in Sekunden, waehrend ein Spiel laeuft (ein Call deckt alle
# Parallelspiele ab; bewusst Luft zum Tarif-Limit lassen)
WM26_LIVE_POLL_SEKUNDEN=7.5

# K.o.-Wertung: 120 = Ergebnis nach Verlängerung zählt, 90 = nur reguläre Spielzeit (SPEC 12.3)
WM26_KO_WERTUNG=120

# Login-Härtung (SPEC 8.1)
WM26_LOGIN_MAX_FEHLVERSUCHE=5
WM26_LOGIN_SPERRE_MINUTEN=15
WM26_SESSION_DAUER_TAGE=30
# Rate-Limit pro IP (gleitendes 60-s-Fenster) VOR der scrypt-Prüfung — wehrt
# unauthentifizierte Login-/Registrierungs-Fluten ab (CPU-DoS-Schutz). 0 = aus.
WM26_LOGIN_RATE_PRO_MINUTE=12
WM26_REGISTRIERUNG_RATE_PRO_MINUTE=6

# Gruppen-Passwort für die Selbst-Registrierung im Login-Screen.
# Leer lassen = Registrierung deaktiviert, nur der Admin legt Nutzer an.
# Öffentlich erreichbar (Funnel): lang & nicht ratbar wählen, z. B. eine
# 4-Wort-Passphrase. Es ist das einzige Tor zur Mitgliedschaft.
WM26_REGISTRIERUNG_PASSWORT=

# Web Push (SPEC 5.5): Schlüsselpaar mit tools/vapid_gen.py erzeugen; leer = Push aus
WM26_VAPID_PRIVATE_KEY=
WM26_VAPID_PUBLIC_KEY=
WM26_VAPID_SUBJECT=mailto:du@example.org
# Tipp-Erinnerung: Standard-Vorlaufzeit in Minuten (jeder Nutzer kann sie in
# der App selbst anpassen oder abbestellen) und Anpfiff-Fenster (gepinnt)
WM26_TIPP_ERINNERUNG_MINUTEN=120
WM26_ANPFIFF_ERINNERUNG_MINUTEN=30

# Aufstellungen von der inoffiziellen ESPN-API (kostenlos, kein Key).
# 0 = Poll abschalten, falls die Quelle mal bricht.
WM26_AUFSTELLUNGEN=1

# Wettquoten via The Odds API (the-odds-api.com, Free Tier reicht).
# Leer = Quoten-Feature aus. Buchmacher-Key z. B. tipico_de; leer = ganze EU-Region.
WM26_QUOTEN_TOKEN=
WM26_QUOTEN_BUCHMACHER=tipico_de
